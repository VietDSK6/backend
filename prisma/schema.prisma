generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  role             Role     @default(STUDENT)
  full_name        String
  avatar_url       String?
  phone            String?
  student_id       String?  @unique
  faculty          String?
  class_name       String?
  bio              String?
  birthday         DateTime?
  social_link      String?
  emergency_contact_name  String?
  emergency_contact_phone String?
  reputation_score Float    @default(0)
  total_hours      Float    @default(0)
  total_points     Int      @default(0)
  current_points   Int      @default(0)
  created_at       DateTime @default(now())

  events              Event[]
  applications        Application[]
  reviews_given       Review[]             @relation("AdminReviews")
  reviews_received    Review[]             @relation("StudentReviews")
  user_badges         UserBadge[]
  notifications       Notification[]
  refresh_tokens      RefreshToken[]
  led_clubs           Club[]               @relation("ClubLeader")
  club_members        ClubMember[]
  reward_transactions RewardTransaction[]
  managed_events      Event[]              @relation("EventManagers")
}

enum Role {
  STUDENT
  ADMIN
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ─── Events ──────────────────────────────────────────

model Event {
  id               String      @id @default(uuid())
  admin_id         String
  title            String
  description      String
  cover_image      String?
  location         String
  start_date       DateTime
  end_date         DateTime
  max_slots        Int
  category         String?
  activity_type_id String?
  status           EventStatus @default(UPCOMING)
  fixed_point      Int         @default(0)
  created_at       DateTime    @default(now())

  admin         User          @relation(fields: [admin_id], references: [id])
  activity_type ActivityType? @relation(fields: [activity_type_id], references: [id])
  applications  Application[]
  reviews       Review[]
  managers      User[]        @relation("EventManagers")
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

// ─── Applications ────────────────────────────────────

model Application {
  id         String            @id @default(uuid())
  event_id   String
  student_id String
  status     ApplicationStatus @default(PENDING)
  applied_at DateTime          @default(now())
  updated_at DateTime          @updatedAt

  event   Event   @relation(fields: [event_id], references: [id])
  student User    @relation(fields: [student_id], references: [id])
  review  Review?

  @@unique([event_id, student_id])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// ─── Reviews ─────────────────────────────────────────

model Review {
  id             String   @id @default(uuid())
  event_id       String
  student_id     String
  admin_id       String
  application_id String   @unique
  rating_score   Int // 1–5
  feedback_text  String?
  created_at     DateTime @default(now())

  event       Event       @relation(fields: [event_id], references: [id])
  student     User        @relation("StudentReviews", fields: [student_id], references: [id])
  admin       User        @relation("AdminReviews", fields: [admin_id], references: [id])
  application Application @relation(fields: [application_id], references: [id])
}

// ─── Badges ──────────────────────────────────────────

model Badge {
  id               String @id @default(uuid())
  name             String
  description      String
  icon_url         String
  required_hours   Float
  activity_type_id String?

  user_badges   UserBadge[]
  activity_type ActivityType? @relation(fields: [activity_type_id], references: [id])
}

model UserBadge {
  id       String   @id @default(uuid())
  user_id  String
  badge_id String
  earned_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id])
  badge Badge @relation(fields: [badge_id], references: [id])

  @@unique([user_id, badge_id])
}

// ─── Notifications ───────────────────────────────────

model NotificationBatch {
  id            String   @id @default(uuid())
  title         String
  message       String
  type          String
  target        String   // ALL | SPECIFIC
  sent_at       DateTime @default(now())

  notifications Notification[]
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  batch_id   String?
  title      String
  message    String
  is_read    Boolean  @default(false)
  type       String
  created_at DateTime @default(now())

  user  User               @relation(fields: [user_id], references: [id])
  batch NotificationBatch? @relation(fields: [batch_id], references: [id])
}

// ─── Activity Types (loại hoạt động) ─────────────────

model ActivityType {
  id         String   @id @default(uuid())
  name       String   @unique
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  events Event[]
  badges Badge[]
}

// ─── FAQs ────────────────────────────────────────────

model FAQ {
  id         String   @id @default(uuid())
  question   String
  answer     String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ─── Clubs (CLB) ─────────────────────────────────────

model Club {
  id          String   @id @default(uuid())
  name        String
  description String?
  cover_image String?
  leader_id   String
  is_reason_required Boolean @default(false)
  is_promise_required Boolean @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  leader  User         @relation("ClubLeader", fields: [leader_id], references: [id])
  members ClubMember[]
}

model ClubMember {
  id        String         @id @default(uuid())
  club_id   String
  user_id   String
  role      ClubMemberRole @default(MEMBER)
  status    ClubMemberStatus @default(PENDING)
  reason    String?
  promise   String?
  joined_at DateTime       @default(now())

  club Club @relation(fields: [club_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([club_id, user_id])
}

enum ClubMemberRole {
  LEADER
  MEMBER
}

enum ClubMemberStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Rewards ─────────────────────────────────────────

model Reward {
  id             String   @id @default(uuid())
  name           String
  description    String
  point_cost     Int
  stock_quantity Int
  image_url      String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  transactions RewardTransaction[]
}

model RewardTransaction {
  id           String                 @id @default(uuid())
  user_id      String
  reward_id    String
  points_spent Int
  voucher_code String                 @unique
  status       RewardTransactionStatus @default(PENDING)
  created_at   DateTime               @default(now())

  user   User   @relation(fields: [user_id], references: [id])
  reward Reward @relation(fields: [reward_id], references: [id])

  @@unique([user_id, reward_id])
}

enum RewardTransactionStatus {
  PENDING
  FULFILLED
  CANCELLED
}
